# FunASR 环境配置

# ── 设备选择 ──────────────────────────────────
# cpu: CPU 推理（默认）
# cuda: GPU 推理（需要 NVIDIA GPU + nvidia-container-toolkit）
DEVICE=cpu

# ── 模型选择（部署时确定，API 不暴露）──────────
# sensevoice:   ASR + 情感 + 事件 (234M) ← 推荐
# paraformer:   中文生产级 ASR + 字级时间戳 (220M)
# fun-asr-nano: LLM-based ASR, 31 语言 (800M)
MODEL=sensevoice

# ── 功能开关 ──────────────────────────────────
# 启动时预加载（true=启动即加载，false=首次请求懒加载）
PRELOAD_ALL=true
# 是否启用流式（WebSocket）
ENABLE_STREAMING=true
# 是否启用 MCP
ENABLE_MCP=true

# ── 服务端口 ──────────────────────────────────
PORT=17767

# ── 并发控制 ──────────────────────────────────
# WORKER_THREADS=8
# CONCURRENT_VAD=4
# CONCURRENT_ASR_ONLINE=4
# CONCURRENT_ASR_OFFLINE=2

# ── 自动清理（任务结果保留天数，0=不清理）───────
DATA_TTL_DAYS=7
