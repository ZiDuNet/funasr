# FunASR 环境配置

# ── 设备选择 ──────────────────────────────────
# cpu: CPU 推理（默认）
# cuda: GPU 推理（需要 NVIDIA GPU + nvidia-container-toolkit + 取消 compose 中 deploy 注释）
DEVICE=cpu

# ── 服务端口 ──────────────────────────────────
PORT=8000

# ── 并发控制 ──────────────────────────────────
# NCPU=4
# WORKER_THREADS=8
# CONCURRENT_VAD=4
# CONCURRENT_ASR_ONLINE=4
# CONCURRENT_ASR_OFFLINE=2

# ── 自动清理 ──────────────────────────────────
# 任务结果和音频文件保留天数（0=不清理）
DATA_TTL_DAYS=7
