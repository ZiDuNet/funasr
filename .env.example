# FunASR 环境配置
# 使用方式: cp .env.example .env 后修改
# Docker Compose 中变量映射见 docker-compose.yml 的 environment 段

# ── 设备选择 ──────────────────────────────────
# cpu: CPU 推理（默认）
# cuda: GPU 推理（需要 NVIDIA GPU + nvidia-container-toolkit）
FUNASR_DEVICE=cpu

# ── 模型选择（部署时确定，API 不暴露）──────────
# 轻量级（CPU/GPU 均可）:
#   sensevoice:           ASR + 情感 + 事件，中英日韩粤，234M
#   paraformer:           中文生产级 ASR + 字级时间戳，220M
#   fun-asr-nano:         LLM-based ASR，31 语言，800M ← 默认
# 大模型（建议 GPU）:
#   qwen3-asr:            52 语言，1.7B，需 GPU + bf16
#   glm-asr-nano:         17 语言，1.5B，需 GPU + bf16
# Whisper 系列:
#   whisper-large-v3:     识别 + 翻译，多语言，1550M
#   whisper-large-v3-turbo: 识别 + 翻译，多语言，809M
#
# 首次使用自动从魔搭下载，切换模型后重启容器即自动下载新模型。
MODEL=fun-asr-nano

# ── 功能开关 ──────────────────────────────────
# 启动时预加载（true=启动即加载，false=首次请求懒加载）
PRELOAD_ALL=true
# 是否启用流式（WebSocket）
ENABLE_STREAMING=true
# 是否启用 MCP
ENABLE_MCP=true

# ── 服务端口 ──────────────────────────────────
FUNASR_PORT=17767

# ── 并发控制 ──────────────────────────────────
# FUNASR_WORKER_THREADS=8
# FUNASR_CONCURRENT_VAD=4
# FUNASR_CONCURRENT_ASR_ONLINE=4
# FUNASR_CONCURRENT_ASR_OFFLINE=2

# ── 自动清理（任务结果保留天数，0=不清理）───────
FUNASR_DATA_TTL_DAYS=7

# ── API Token 认证（生产环境建议设置）──────────
# 留空 = 不认证（开发模式）
# 设置后，所有 API 调用需带 Authorization: Bearer <token>
# WebSocket 通过 ?token=xxx 传递
API_TOKEN=
