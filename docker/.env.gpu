# FunASR GPU 环境配置
# 使用: cp docker/.env.gpu .env && cp docker/docker-compose.gpu.yml docker-compose.override.yml && docker compose up -d

# ── 设备 ────────────────────────────────────
FUNASR_DEVICE=cuda

# ── 模型（GPU 可跑大模型）────────────────────
#   sensevoice:           ASR + 情感 + 事件，中英日韩粤，234M
#   paraformer:           中文生产级 ASR，220M
#   fun-asr-nano:         LLM-based ASR，31 语言，800M ← 默认
#   qwen3-asr:            52 语言，1.7B（bf16，Ampere+ GPU）
#   glm-asr-nano:         17 语言，1.5B（bf16，Ampere+ GPU）
#   whisper-large-v3:     多语言识别+翻译，1550M
#   whisper-large-v3-turbo: 多语言识别+翻译，809M
MODEL=fun-asr-nano

# ── 功能开关 ──────────────────────────────────
PRELOAD_ALL=true
ENABLE_STREAMING=true
ENABLE_MCP=true

# ── 服务端口 ──────────────────────────────────
FUNASR_PORT=17767

# ── 并发控制（GPU 可放开）────────────────────
FUNASR_NCPU=4
FUNASR_WORKER_THREADS=8
FUNASR_CONCURRENT_VAD=4
FUNASR_CONCURRENT_ASR_ONLINE=4
FUNASR_CONCURRENT_ASR_OFFLINE=2
FUNASR_CONCURRENT_PUNC=2
FUNASR_CONCURRENT_SV=2
FUNASR_CONCURRENT_EMOTION=2

# ── 任务 ────────────────────────────────────
FUNASR_MAX_TASKS=1000
FUNASR_DATA_TTL_DAYS=7

# ── API Token（生产环境建议设置）──────────────
API_TOKEN=
