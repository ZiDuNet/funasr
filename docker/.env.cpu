# FunASR CPU 环境配置
# 使用: cp docker/.env.cpu .env && cp docker/docker-compose.cpu.yml docker-compose.override.yml && docker compose up -d

# ── 设备 ────────────────────────────────────
FUNASR_DEVICE=cpu

# ── 模型（CPU 推荐）─────────────────────────
#   sensevoice:      ASR + 情感 + 事件，中英日韩粤，234M
#   paraformer:      中文生产级 ASR + 字级时间戳，220M
#   fun-asr-nano:    LLM-based ASR，31 语言，800M ← 默认
MODEL=fun-asr-nano

# ── 功能开关 ──────────────────────────────────
PRELOAD_ALL=true
ENABLE_STREAMING=true
ENABLE_MCP=true

# ── 服务端口 ──────────────────────────────────
FUNASR_PORT=17767

# ── 并发控制（CPU 建议保守）──────────────────
FUNASR_NCPU=4
FUNASR_WORKER_THREADS=4
FUNASR_CONCURRENT_VAD=2
FUNASR_CONCURRENT_ASR_ONLINE=2
FUNASR_CONCURRENT_ASR_OFFLINE=1
FUNASR_CONCURRENT_PUNC=1
FUNASR_CONCURRENT_SV=1
FUNASR_CONCURRENT_EMOTION=1

# ── 任务 ────────────────────────────────────
FUNASR_MAX_TASKS=100
FUNASR_DATA_TTL_DAYS=7

# ── API Token（生产环境建议设置）──────────────
API_TOKEN=
